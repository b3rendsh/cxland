; SNIOS for RomWBW HBIOS serial port

; On a Z180 platform you can use RomWBW configuration setting:
; ASCISWAP .SET TRUE
; This will swap the logical ASCI port numbers, so unit 1 is port a.
; On port a you can use 115200 baud, on port b use 57600 baud because 
; the Z180 port b misses RTS/CTS signals.
;
UNIT		equ	1	; use port b (or port a if ports are swapped)

; Options for DRI SNIOS
; 
always$retry	equ	0	; match cpnet-0.8/P112 setting
timeout$retries equ	100	; timeout a max of 100 times
max$retries	equ	10	; send message max of 10 times

; Timeout values for chrio.asm (status loop counts)
;
startTimeout	equ	0000h	; for first char on receive
charTimeout	equ	0200h	; between adjacent chars of receive
